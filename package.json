{
    "name": "seyfert-template",
    "version": "1.0.0",
    "description": "A simple template for Seyfert projects.",
    "main": "./dist/index.js",
    "author": "Ganyu Studios",
    "type": "module",
    "license": "MIT",
    "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
    "scripts": {
        "build": "tsc",
        "test": "tsx ./src/index.ts --debug --dev",
        "dev": "tsx ./src/index.ts --dev",
        "start": "node ./dist/index.js",
        "lint": "biome lint --write .",
        "format": "biome check --write .",
        "typecheck": "tsc --noEmit",
        "prepare": "husky"
    },
    "contributors": [
        {
            "url": "https://github.com/EvilG-MC",
            "name": "JustEvil"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Ganyu-Studios/seyfert-template.git"
    },
    "lint-staged": {
        "{*.ts,*.json}": [
            "pnpm format"
        ]
    },
    "keywords": [
        "seyfert",
        "template",
        "typescript",
        "node",
        "discord",
        "bot",
        "framework"
    ],
    "dependencies": {
        "dotenv": "^17.3.1",
        "seyfert": "4.2.3-dev-22939270682.0",
        "yunaforseyfert": "^1.1.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.7",
        "@types/node": "^25.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    }
}
