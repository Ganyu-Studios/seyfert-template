{
    "name": "seyfert-template",
    "version": "1.0.0",
    "description": "A simple template for Seyfert projects.",
    "main": "./dist/index.js",
    "author": "Ganyu Studios",
    "type": "module",
    "license": "MIT",
    "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
    "scripts": {
        "build": "tsc",
        "test": "tsx ./src/index.ts --debug --dev",
        "dev": "tsx ./src/index.ts --dev",
        "start": "node ./dist/index.js",
        "lint": "biome lint --write .",
        "format": "biome check --write .",
        "typecheck": "tsc --noEmit",
        "prepare": "husky"
    },
    "contributors": [
        {
            "url": "https://github.com/EvilG-MC",
            "name": "JustEvil"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Ganyu-Studios/seyfert-template.git"
    },
    "lint-staged": {
        "{*.ts,*.json}": [
            "pnpm format"
        ]
    },
    "keywords": [
        "seyfert",
        "template",
        "typescript",
        "node",
        "discord",
        "bot",
        "framework"
    ],
    "dependencies": {
        "dotenv": "^17.4.2",
        "seyfert": "4.3.0",
        "yunaforseyfert": "^1.1.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.11",
        "@types/node": "^25.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    }
}
