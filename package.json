{
    "name": "seyfert-template",
    "version": "1.0.0",
    "description": "A simple template for Seyfert projects.",
    "main": "./dist/index.js",
    "author": "Ganyu Studios",
    "type": "module",
    "license": "MIT",
    "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
    "scripts": {
        "build": "tsc",
        "test": "tsx ./src/index.ts --debug --dev",
        "dev": "tsx ./src/index.ts --dev",
        "start": "node ./dist/index.js",
        "lint": "biome lint --write .",
        "format": "biome check --write .",
        "typecheck": "tsc --noEmit",
        "prepare": "husky"
    },
    "contributors": [
        {
            "url": "https://github.com/EvilG-MC",
            "name": "JustEvil"
        }
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Ganyu-Studios/seyfert-template.git"
    },
    "lint-staged": {
        "{*.ts,*.json}": [
            "pnpm format"
        ]
    },
    "keywords": [
        "seyfert",
        "template",
        "typescript",
        "node",
        "discord",
        "bot",
        "framework"
    ],
    "dependencies": {
        "dotenv": "^17.4.2",
        "seyfert": "5.0.1-dev-28545549375.0",
        "yunaforseyfert": "^1.1.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.2",
        "@types/node": "^26.1.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "tsx": "^4.23.0",
        "typescript": "^6.0.3"
    }
}
